# AbleWork 프로덕션 환경변수 → SSM Parameter Store(/ablework/api/prod/*) 등록용.
#   사용: cp .env.prod.example .env.prod  후 값 채우고  bash 02-ssm-params.sh
#   .env.prod 는 git-ignore 됨(절대 커밋 금지). 비밀은 SecureString 으로 저장됨.
#   값이 빈 줄은 자동 스킵된다.

# ── 도메인 연동(단일 도메인 work.abmwc.net) ──────────────────────────
CORS_ORIGINS=https://work.abmwc.net
FRONTEND_URL=https://work.abmwc.net

# ── JWT ───────────────────────────────────────────────────────────
# JWT_SECRET 은 비워두면 02-ssm-params.sh 가 자동 생성한다(직접 넣어도 됨).
# JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── 메일(Gmail SMTP) ──────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=abmw.corp@gmail.com
MAIL_PASS=
MAIL_FROM=abmw.corp@gmail.com

# ── 서버/스토리지 ─────────────────────────────────────────────────
PORT=3001
AWS_REGION=ap-northeast-2
S3_BUCKET=ablework-prod-files

# ── 데이터 계층(자동 등록) ────────────────────────────────────────
# DATABASE_URL / REDIS_URL 은 04-data.sh 가 RDS/ElastiCache 생성 후 SSM에 기록한다.
# 수동으로 채우려면 주석을 풀고 값을 넣으면 된다.
# DATABASE_URL=postgresql://ablework:PASSWORD@HOST:5432/ablework?schema=public
# REDIS_URL=redis://HOST:6379
