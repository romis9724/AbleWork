# 앱 서버(/opt/ablework/.env.app) — API 런타임 환경변수.
# __PLACEHOLDER__ 는 배포 시 DB 서버 .env.db 와 동일한 값으로 채운다(자동 생성).
NODE_ENV=production
PORT=3001

# DB / Redis — DB 서버(LAN 192.168.10.151)
DATABASE_URL=postgresql://ablework:__POSTGRES_PASSWORD__@192.168.10.151:5432/ablework?schema=public
REDIS_URL=redis://:__REDIS_PASSWORD__@192.168.10.151:6379

# 인증
JWT_SECRET=__GENERATE__
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# 공개 주소 (web=18000, api=18001)
CORS_ORIGINS=http://59.29.231.14:18000
FRONTEND_URL=http://59.29.231.14:18000

# 메일 (Gmail SMTP) — MAIL_USER/PASS/FROM 는 본인이 채운다(앱 비밀번호)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=

# 오브젝트 스토리지 (DB 서버 MinIO)
MINIO_ENDPOINT=192.168.10.151
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=ablework
MINIO_ROOT_PASSWORD=__MINIO_ROOT_PASSWORD__
MINIO_BUCKET=ablework
