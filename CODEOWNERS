# CODEOWNERS — 경로별 리뷰 책임자
#
# GitLab은 루트/`.gitlab/`/`docs/`의 CODEOWNERS를 인식한다. MR에서 해당 경로가
# 변경되면 지정된 오너가 승인 대상으로 자동 요청된다.
#
# ⚠️ 아래 핸들(@abmwc/*)은 **예시**다. 실제 GitLab 그룹/사용자 핸들로 교체할 것.
# (핸들이 유효하지 않으면 해당 규칙은 무시되지만 파일 자체는 유효하다.)

# 기본 — 명시되지 않은 모든 변경
*                               @abmwc/maintainers

# 백엔드
/apps/api/                      @abmwc/backend
/apps/api/prisma/               @abmwc/backend
/packages/                      @abmwc/backend @abmwc/frontend

# 프런트엔드 / 모바일
/apps/web/                      @abmwc/frontend
/apps/mobile/                   @abmwc/mobile

# 인프라 / 배포 — 운영 영향, 신중 리뷰
/deploy/                        @abmwc/devops
/.gitlab-ci.yml                 @abmwc/devops

# 설계·의사결정 문서 — 변경 시 메인테이너 확인
/docs/design/                   @abmwc/maintainers
/docs/adr/                      @abmwc/maintainers
/CLAUDE.md                      @abmwc/maintainers
