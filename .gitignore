# 원본 참조 메뉴얼 — git 추적 제외
refs/

# 로컬 Claude Code 설정
.claude/

# 환경 변수
.env
.env.local
.env.*.local
!.env.example
!apps/api/.env.example
!apps/web/.env.example

# AWS 배포 비밀(SSM 주입용) — 절대 커밋 금지. .example 만 추적.
deploy/aws/.env.prod
!deploy/aws/.env.prod.example
# AWS 배포 상태(리소스 ID 캐시)
deploy/aws/.state/

# 빌드 산출물
node_modules/
dist/
.next/
.turbo/
coverage/
*.tsbuildinfo

# 공유 패키지는 TS 소스만 사용 — src에 컴파일 산출물 emit 방지 (tsconfig noEmit이 1차 방어)
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map

# Playwright 실행 산출물 (E2E 실패 아티팩트 — 추적 제외)
test-results/
playwright-report/
blob-report/
.playwright/

# OS
.DS_Store
Thumbs.db
