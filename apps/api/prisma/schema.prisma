  formula           String  @db.Text
  filterLeaveTypeId String? @map("filter_leave_type_id")
  filterShiftTypeId String? @map("filter_shift_type_id")
  dateSpecified     String? @map("date_specified") @db.VarChar(10)
  positionIds       Json?   @map("position_ids")
  sortOrder         Int     @map("sort_order")
  isActive          Boolean @default(true) @map("is_active")

  company         Company    @relation(fields: [companyId], references: [id])
  filterLeaveType LeaveType? @relation(fields: [filterLeaveTypeId], references: [id])
  filterShiftType ShiftType? @relation(fields: [filterShiftTypeId], references: [id])

  @@map("custom_report_columns")
}

