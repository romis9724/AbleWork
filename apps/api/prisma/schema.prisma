  createdAt            DateTime @default(now()) @map("created_at")

  company  Company   @relation(fields: [companyId], references: [id])
  position Position? @relation(fields: [positionId], references: [id])

  @@map("standardization_rules")
}

model ReportSnapshotTemplate {
  id                String  @id @default(uuid())
  companyId         String  @map("company_id")
  name              String  @db.VarChar(100)
  columnConfig      Json    @map("column_config")
  includeLeaveStats Boolean @default(true) @map("include_leave_stats")
  isActive          Boolean @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")

  company   Company          @relation(fields: [companyId], references: [id])
  snapshots ReportSnapshot[]

  @@map("report_snapshot_templates")
}

model ReportSnapshot {
  id           String    @id @default(uuid())
  companyId    String    @map("company_id")
  name         String?   @db.VarChar(200)
  templateId   String?   @map("template_id")
  periodStart  DateTime  @db.Date @map("period_start")
  periodEnd    DateTime  @db.Date @map("period_end")
  columnConfig Json      @map("column_config")
  isLocked     Boolean   @default(false) @map("is_locked")
  lockedBy     String?   @map("locked_by")
  lockedAt     DateTime? @map("locked_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  company  Company                 @relation(fields: [companyId], references: [id])
