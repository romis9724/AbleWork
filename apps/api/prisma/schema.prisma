// AbleWork ERP — Prisma Schema
// 버전: 1.0.0 (ERD v2.2.0 기반, 52개 테이블)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ════════════════════════════════════════════════
// 1. 그룹 / 회사 / 조직
// ════════════════════════════════════════════════

// 그룹(계열사 묶음) — 한 그룹에 여러 회사가 속한다.
// 상위 역할/결제는 두지 않는다(멤버십만). 회사 묶음 컨테이너 역할.
model Group {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  companies Company[]

  @@map("groups")
}

model Company {
  id             String   @id @default(uuid())
  groupId        String   @map("group_id")
  name           String   @db.VarChar(100)
  businessNumber String?  @db.VarChar(20) @map("business_number")
  foundedAt      DateTime? @db.Date @map("founded_at")
  timezone       String   @default("Asia/Seoul")
  locale         String   @default("ko")
  countryCode    String   @default("KR") @map("country_code") @db.VarChar(2)
  logoUrl        String?  @map("logo_url")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  group                Group                    @relation(fields: [groupId], references: [id])
  organizations        Organization[]
  holidays             CompanyHoliday[]
  settings             CompanySetting[]
  employees            Employee[]
  positions            Position[]
  shiftTypes           ShiftType[]
  shiftTemplates       ShiftTemplate[]
  schedulePatterns     SchedulePattern[]
  leaveGroups          LeaveGroup[]
  leaveAccrualRules    LeaveAccrualRule[]
  customRequestTypes   CustomRequestType[]
  approvalRules        ApprovalRule[]
  documentForms        DocumentForm[]
  documentNumberRules  DocumentNumberRule[]
  documents            Document[]
  sharedApprovalLines  SharedApprovalLine[]
  standardizationRules StandardizationRule[]
  snapshotTemplates    ReportSnapshotTemplate[]
  reportSnapshots      ReportSnapshot[]
  customReportColumns  CustomReportColumn[]
  messageTemplates     MessageTemplate[]
  messageAutomations   MessageAutomation[]
  messages             Message[]
  notificationRules    NotificationRule[]
  employeeCustomFields EmployeeCustomField[]
  documentAttachments  DocumentAttachment[]
  formCategories       FormCategory[]
  documentCategories   DocumentCategory[]
  auditLogs            AuditLog[]
  messengerAccounts    MessengerAccount[]
  errorAnalysisLogs    ErrorAnalysisLog[]

  @@index([groupId])
  @@map("companies")
}

model Organization {
  id         String   @id @default(uuid())
  companyId  String   @map("company_id")
  parentId   String?  @map("parent_id")
  name       String   @db.VarChar(100)
  depth      Int      @default(0)
  sortOrder  Int      @default(0) @map("sort_order")
  approverId String?  @map("approver_id")
  // AP-04-07 문서담당자 (부서별). null이면 approverId(팀장)로 fallback.
  docManagerId String? @map("doc_manager_id")
  // 부서 주소 (선택 — 지도/연락처 표기용)
  address    String?  @db.Text
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  company          Company                @relation(fields: [companyId], references: [id])
  parent           Organization?          @relation("OrgHierarchy", fields: [parentId], references: [id])
  children         Organization[]         @relation("OrgHierarchy")
  approver         Employee?              @relation("OrgApprover", fields: [approverId], references: [id])
  docManager       Employee?              @relation("OrgDocManager", fields: [docManagerId], references: [id], onDelete: SetNull)
  docManagers      OrganizationDocManager[]
  deptSteps        ApprovalStep[]         @relation("StepDept")
  employeeOrgs     EmployeeOrganization[]
  timeclockAreas   TimeclockArea[]
  shifts           Shift[]

  @@index([companyId, isActive])
  @@map("organizations")
}

// AP-04-07 부서 문서담당자 (다중) — 부서협조/부서수신 step을 처리할 수 있는 담당자 집합.
// 단일 docManagerId는 1차(primary) fallback으로 유지(점진 이관). sortOrder 최소 = 대표 담당자.
model OrganizationDocManager {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  employeeId     String   @map("employee_id")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation("DocManagerEmployee", fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([organizationId, employeeId])
  @@index([employeeId])
  @@map("organization_doc_managers")
}

model CompanyHoliday {
  id            String   @id @default(uuid())
  companyId     String   @map("company_id")
  holidayDate   DateTime @db.Date @map("holiday_date")
  name          String   @db.VarChar(100)
  isAnnualRepeat Boolean @default(false) @map("is_annual_repeat")
  type          String   @default("custom") @db.VarChar(20)

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, holidayDate])
  @@map("company_holidays")
}

model CompanySetting {
  id        String @id @default(uuid())
  companyId String @map("company_id")
  section   String @db.VarChar(50)
  key       String @db.VarChar(100)
  value     Json

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, section, key])
  @@index([companyId, section, key])
  @@map("company_settings")
}

// ════════════════════════════════════════════════
// 2. 계정 / 직원
// ════════════════════════════════════════════════

model User {
  id               String   @id @default(uuid())
  email            String   @unique @db.VarChar(255)
  passwordHash     String   @map("password_hash")
  name             String   @db.VarChar(50)
  phone            String?  @db.VarChar(20)
  timezone         String   @default("Asia/Seoul")
  twoFactorEnabled Boolean  @default(false) @map("two_factor_enabled")
  isActive         Boolean  @default(true) @map("is_active")
  // 마지막으로 선택한 활성 회사 (멀티컴퍼니 전환 기억). FK 강제 안 함 — 로그인 시 유효성 재검증.
  lastCompanyId    String?  @map("last_company_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // 멀티컴퍼니: 한 사용자가 회사마다 Employee 레코드를 가질 수 있다 (1:N).
  employees           Employee[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash") @db.VarChar(128)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model Employee {
  id             String    @id @default(uuid())
  companyId      String    @map("company_id")
  // 멀티컴퍼니: userId는 더 이상 전역 unique가 아니다. 한 사용자가 여러 회사에 소속 가능.
  // 회사 내 중복 멤버십만 @@unique([companyId, userId])로 방지한다.
  userId         String?   @map("user_id")
  employeeNumber String?   @map("employee_number") @db.VarChar(50)
  name           String    @db.VarChar(50)
  phone          String?   @db.VarChar(20)
  joinedAt       DateTime  @db.Date @map("joined_at")
  resignedAt     DateTime? @db.Date @map("resigned_at")
  employmentType String    @map("employment_type") @db.VarChar(20)
  accessLevel    String    @map("access_level") @db.VarChar(20)
  deviceId       String?   @map("device_id") @db.VarChar(255)
  deviceBoundAt  DateTime? @map("device_bound_at")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  company               Company                    @relation(fields: [companyId], references: [id])
  user                  User?                      @relation(fields: [userId], references: [id])
  organizations         EmployeeOrganization[]
  positions             EmployeePosition[]
  wageInfos             WageInfo[]
  customFieldValues     EmployeeCustomFieldValue[]
  shifts                Shift[]
  attendances           Attendance[]
  leaveBalances         LeaveBalance[]
  leaves                Leave[]
  requests              Request[]
  draftedDocuments      Document[]                 @relation("DocumentDrafter")
  approvalSteps         ApprovalStep[]             @relation("StepAssignee")
  proxySteps            ApprovalStep[]             @relation("StepProxy")
  principalProxySettings ProxySettings[]           @relation("ProxPrincipal")
  proxyProxySettings    ProxySettings[]            @relation("ProxyAgent")
  approvalHistories     ApprovalHistory[]
  managedOrgs           Organization[]             @relation("OrgApprover")
  managedDocOrgs        Organization[]             @relation("OrgDocManager")
  docManagerOf          OrganizationDocManager[]   @relation("DocManagerEmployee")
  confirmedShifts       Shift[]                    @relation("ShiftConfirmer")
  createdShifts         Shift[]                    @relation("ShiftCreator")
  confirmedAttendances  Attendance[]               @relation("AttendanceConfirmer")
  resolvedErrorLogs     ErrorAnalysisLog[]         @relation("ErrorResolver")
  lockedSnapshots       ReportSnapshot[]
  sentMessages          Message[]
  uploadedAttachments   DocumentAttachment[]       @relation("AttachmentUploader")
  createdSharedLines    SharedApprovalLine[]       @relation("SharedLineCreatedBy")
  messengerAccounts     MessengerAccount[]

  @@unique([companyId, userId])
  @@index([companyId, isActive])
  @@index([companyId, accessLevel])
  @@index([userId])
  @@map("employees")
}

model EmployeeOrganization {
  employeeId     String  @map("employee_id")
  organizationId String  @map("organization_id")
  isPrimary      Boolean @default(false) @map("is_primary")

  employee     Employee     @relation(fields: [employeeId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@id([employeeId, organizationId])
  @@map("employee_organizations")
}

model Position {
  id        String @id @default(uuid())
  companyId String @map("company_id")
  name      String @db.VarChar(100)
  color     String? @db.VarChar(20)
  sortOrder Int    @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  company   Company           @relation(fields: [companyId], references: [id])
  employees EmployeePosition[]
  approvalRuleDetails ApprovalRuleDetail[]
  standardizationRules StandardizationRule[]

  @@map("positions")
}

model EmployeePosition {
  employeeId String @map("employee_id")
  positionId String @map("position_id")

  employee Employee @relation(fields: [employeeId], references: [id])
  position Position @relation(fields: [positionId], references: [id])

  @@id([employeeId, positionId])
  @@map("employee_positions")
}

model EmployeeCustomField {
  id        String  @id @default(uuid())
  companyId String  @map("company_id")
  fieldName String  @map("field_name") @db.VarChar(100)
  fieldType String  @map("field_type") @db.VarChar(30)
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  company Company                    @relation(fields: [companyId], references: [id])
  values  EmployeeCustomFieldValue[]

  @@map("employee_custom_fields")
}

model EmployeeCustomFieldValue {
  id         String @id @default(uuid())
  employeeId String @map("employee_id")
  fieldId    String @map("field_id")
  value      String? @db.Text

  employee Employee            @relation(fields: [employeeId], references: [id])
  field    EmployeeCustomField @relation(fields: [fieldId], references: [id])

  @@unique([employeeId, fieldId])
  @@map("employee_custom_field_values")
}

// ════════════════════════════════════════════════
// 3. 근로정보
// ════════════════════════════════════════════════

model WageInfo {
  id                      String   @id @default(uuid())
  employeeId              String   @map("employee_id")
  hourlyWage              Int      @default(0) @map("hourly_wage")
  contractedWorkDays      String   @map("contracted_work_days") @db.VarChar(50)
  contractedHoursPerWeek  Decimal  @map("contracted_hours_per_week") @db.Decimal(5, 2)
  weeklyPaidHolidayDay    String?  @map("weekly_paid_holiday_day") @db.VarChar(10)
  maxHoursPerWeek         Decimal  @default(52) @map("max_hours_per_week") @db.Decimal(5, 2)
  effectiveFrom           DateTime @db.Date @map("effective_from")
  createdAt               DateTime @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId, effectiveFrom(sort: Desc)])
  @@map("wage_infos")
}

// ════════════════════════════════════════════════
// 4. 출퇴근 장소
// ════════════════════════════════════════════════

model TimeclockArea {
  id                    String   @id @default(uuid())
  organizationId        String   @map("organization_id")
  name                  String   @db.VarChar(100)
  authMethod            String   @map("auth_method") @db.VarChar(20)
  locationLat           Decimal? @map("location_lat") @db.Decimal(10, 7)
  locationLng           Decimal? @map("location_lng") @db.Decimal(10, 7)
  locationRadiusMeters  Int?     @map("location_radius_meters")
  wifiSsid              String?  @map("wifi_ssid") @db.VarChar(255)
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  attendances  Attendance[]

  @@map("timeclock_areas")
}

// ════════════════════════════════════════════════
// 5. 근무일정
// ════════════════════════════════════════════════

model ShiftType {
  id                 String  @id @default(uuid())
  companyId          String  @map("company_id")
  name               String  @db.VarChar(100)
  category           String  @db.VarChar(30)
  color              String? @db.VarChar(20)
  isOvertime         Boolean @default(false) @map("is_overtime")
  isNight            Boolean @default(false) @map("is_night")
  isHoliday          Boolean @default(false) @map("is_holiday")
  isDeemedWork       Boolean @default(false) @map("is_deemed_work")
  deemedWorkHours    Int?    @map("deemed_work_hours")
  noClockInRequired  Boolean @default(false) @map("no_clock_in_required")
  confirmedAlert     String? @map("confirmed_alert") @db.Text
  noteTemplates      Json?   @map("note_templates")
  orgScopeIds        Json?   @map("org_scope_ids")
  positionScopeIds   Json?   @map("position_scope_ids")
  isActive           Boolean @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  company             Company              @relation(fields: [companyId], references: [id])
  templates           ShiftTemplate[]
  shifts              Shift[]
  customReportColumns CustomReportColumn[]

  @@index([companyId, isActive])
  @@map("shift_types")
}

model ShiftTemplate {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  shiftTypeId String   @map("shift_type_id")
  name        String   @db.VarChar(100)
  code        String?  @db.VarChar(20)
  startTime   DateTime @map("start_time") @db.Time
  endTime     DateTime @map("end_time") @db.Time
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  company   Company   @relation(fields: [companyId], references: [id])
  shiftType ShiftType @relation(fields: [shiftTypeId], references: [id])
  shifts    Shift[]

  @@map("shift_templates")
}

model SchedulePattern {
  id               String  @id @default(uuid())
  companyId        String  @map("company_id")
  name             String  @db.VarChar(100)
  description      String? @db.Text
  repeatCycleDays  Int     @map("repeat_cycle_days")
  patternDefinition Json   @map("pattern_definition")
  holidayHandling  String  @map("holiday_handling") @db.VarChar(30)
  isActive         Boolean @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])

  @@map("schedule_patterns")
}

model Shift {
  id             String   @id @default(uuid())
  employeeId     String   @map("employee_id")
  organizationId String   @map("organization_id")
  shiftTypeId    String   @map("shift_type_id")
  templateId     String?  @map("template_id")
  startAt        DateTime @map("start_at")
  endAt          DateTime @map("end_at")
  isOffsite      Boolean  @default(false) @map("is_offsite")
  offsiteAddress String?  @map("offsite_address") @db.Text
  offsiteLat     Decimal? @map("offsite_lat") @db.Decimal(10, 7)
  offsiteLng     Decimal? @map("offsite_lng") @db.Decimal(10, 7)
  status         String   @default("draft") @db.VarChar(20)
  confirmedBy    String?  @map("confirmed_by")
  confirmedAt    DateTime? @map("confirmed_at")
  createdBy      String   @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  employee     Employee       @relation(fields: [employeeId], references: [id])
  organization Organization   @relation(fields: [organizationId], references: [id])
  shiftType    ShiftType      @relation(fields: [shiftTypeId], references: [id])
  template     ShiftTemplate? @relation(fields: [templateId], references: [id])
  confirmer    Employee?      @relation("ShiftConfirmer", fields: [confirmedBy], references: [id])
  creator      Employee       @relation("ShiftCreator", fields: [createdBy], references: [id])
  breakTimes   ShiftBreakTime[]
  attendance   Attendance?

  @@index([employeeId, startAt, endAt])
  @@index([organizationId, startAt, endAt])
  @@map("shifts")
}

model ShiftBreakTime {
  id              String   @id @default(uuid())
  shiftId         String   @map("shift_id")
  breakType       String   @map("break_type") @db.VarChar(20)
  startTime       DateTime @map("start_time") @db.Time
  endTime         DateTime @map("end_time") @db.Time
  durationMinutes Int      @map("duration_minutes")
  isAuto          Boolean  @default(true) @map("is_auto")

  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@map("shift_break_times")
}

// ════════════════════════════════════════════════
// 6. 출퇴근 기록
// ════════════════════════════════════════════════

model Attendance {
  id              String    @id @default(uuid())
  employeeId      String    @map("employee_id")
  shiftId         String?   @unique @map("shift_id")
  timeclockAreaId String?   @map("timeclock_area_id")
  clockInAt       DateTime  @map("clock_in_at")
  clockOutAt      DateTime? @map("clock_out_at")
  clockInLat      Decimal?  @map("clock_in_lat") @db.Decimal(10, 7)
  clockInLng      Decimal?  @map("clock_in_lng") @db.Decimal(10, 7)
  clockOutLat     Decimal?  @map("clock_out_lat") @db.Decimal(10, 7)
  clockOutLng     Decimal?  @map("clock_out_lng") @db.Decimal(10, 7)
  clockInMethod   String?   @map("clock_in_method") @db.VarChar(20)
  clockOutMethod  String?   @map("clock_out_method") @db.VarChar(20)
  status          String    @default("normal") @db.VarChar(20)
  isOncall        Boolean   @default(false) @map("is_oncall")
  note            String?   @db.Text
  isConfirmed     Boolean   @default(false) @map("is_confirmed")
  confirmedBy     String?   @map("confirmed_by")
  confirmedAt     DateTime? @map("confirmed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  employee      Employee       @relation(fields: [employeeId], references: [id])
  shift         Shift?         @relation(fields: [shiftId], references: [id])
  timeclockArea TimeclockArea? @relation(fields: [timeclockAreaId], references: [id])
  confirmer     Employee?      @relation("AttendanceConfirmer", fields: [confirmedBy], references: [id])
  breaks        AttendanceBreak[]

  @@index([employeeId, clockInAt])
  @@index([employeeId, status])
  @@map("attendances")
}

model AttendanceBreak {
  id           String    @id @default(uuid())
  attendanceId String    @map("attendance_id")
  breakType    String    @map("break_type") @db.VarChar(20)
  startAt      DateTime  @map("start_at")
  endAt        DateTime? @map("end_at")
  isManual     Boolean   @default(false) @map("is_manual")

  attendance Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  @@map("attendance_breaks")
}

// ════════════════════════════════════════════════
// 7. 휴가
// ════════════════════════════════════════════════

model LeaveGroup {
  id              String @id @default(uuid())
  companyId       String @map("company_id")
  name            String @db.VarChar(100)
  code            String? @db.VarChar(20)
  overageLimitDays Int   @default(0) @map("overage_limit_days")
  isActive        Boolean @default(true) @map("is_active")

  company       Company           @relation(fields: [companyId], references: [id])
  leaveTypes    LeaveType[]
  accrualRules  LeaveAccrualRule[]

  @@map("leave_groups")
}

model LeaveType {
  id                          String  @id @default(uuid())
  groupId                     String  @map("group_id")
  name                        String  @db.VarChar(100)
  displayName                 String? @map("display_name") @db.VarChar(100)
  code                        String? @db.VarChar(20)
  timeOption                  String  @default("full_day") @map("time_option") @db.VarChar(20)
  paidHours                   Int?    @map("paid_hours")
  deductionDays               Decimal @default(1) @map("deduction_days") @db.Decimal(5, 2)
  specialOption               String? @map("special_option") @db.VarChar(30)
  minConsecutiveDays          Int?    @map("min_consecutive_days")
  maxConsecutiveDays          Int?    @map("max_consecutive_days")
  includeHolidaysInConsecutive Boolean @default(false) @map("include_holidays_in_consecutive")
  allowArbitraryTime          Boolean @default(false) @map("allow_arbitrary_time")
  timeFixedType               String? @map("time_fixed_type") @db.VarChar(30)
  baseHours                   Decimal? @map("base_hours") @db.Decimal(5, 2)
  confirmBeforeClockin        String? @map("confirm_before_clockin") @db.Text
  reasonDisplay               Boolean @default(false) @map("reason_display")
  deleteEnclosedShifts        Boolean @default(false) @map("delete_enclosed_shifts")
  orgScopeIds                 Json?   @map("org_scope_ids")
  positionScopeIds            Json?   @map("position_scope_ids")
  isActive                    Boolean @default(true) @map("is_active")

  group    LeaveGroup     @relation(fields: [groupId], references: [id])
  balances LeaveBalance[]
  leaves   Leave[]
  messageAutomations MessageAutomation[]
  customReportColumns CustomReportColumn[]

  @@map("leave_types")
}

model LeaveAccrualRule {
  id          String  @id @default(uuid())
  companyId   String  @map("company_id")
  leaveGroupId String @map("leave_group_id")
  name        String  @db.VarChar(100)
  memo        String? @db.Text
  isActive    Boolean @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  company    Company              @relation(fields: [companyId], references: [id])
  leaveGroup LeaveGroup           @relation(fields: [leaveGroupId], references: [id])
  items      LeaveAccrualRuleItem[]

  @@map("leave_accrual_rules")
}

model LeaveAccrualRuleItem {
  id             String  @id @default(uuid())
  ruleId         String  @map("rule_id")
  accrualBasis   String  @map("accrual_basis") @db.VarChar(10)
  tenureMonths   Int?    @map("tenure_months")
  tenureYears    Int?    @map("tenure_years")
  accrualDays    Decimal @map("accrual_days") @db.Decimal(5, 2)
  validMonths    Int?    @map("valid_months")
  periodStartMd  String? @map("period_start_md") @db.VarChar(5)
  periodEndMd    String? @map("period_end_md") @db.VarChar(5)
  sortOrder      Int     @map("sort_order")

  rule LeaveAccrualRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@map("leave_accrual_rule_items")
}

model LeaveBalance {
  id            String   @id @default(uuid())
  employeeId    String   @map("employee_id")
  leaveTypeId   String   @map("leave_type_id")
  year          Int
  accruedDays   Decimal  @default(0) @map("accrued_days") @db.Decimal(7, 2)
  usedDays      Decimal  @default(0) @map("used_days") @db.Decimal(7, 2)
  remainingDays Decimal  @default(0) @map("remaining_days") @db.Decimal(7, 2)
  expiresAt     DateTime? @db.Date @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  employee  Employee  @relation(fields: [employeeId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([employeeId, leaveTypeId, year])
  @@index([employeeId])
  @@map("leave_balances")
}

model Leave {
  id          String   @id @default(uuid())
  employeeId  String   @map("employee_id")
  leaveTypeId String   @map("leave_type_id")
  startDate   DateTime @db.Date @map("start_date")
  endDate     DateTime @db.Date @map("end_date")
  startTime   DateTime? @db.Time @map("start_time")
  endTime     DateTime? @db.Time @map("end_time")
  daysUsed    Decimal  @default(1) @map("days_used") @db.Decimal(5, 2)
  status      String   @default("APPROVED") @db.VarChar(20)
  reason      String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  employee  Employee  @relation(fields: [employeeId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@index([employeeId, startDate, endDate])
  @@map("leaves")
}

// ════════════════════════════════════════════════
// 8. 요청
// ════════════════════════════════════════════════

model CustomRequestType {
  id               String  @id @default(uuid())
  companyId        String  @map("company_id")
  name             String  @db.VarChar(100)
  isActive         Boolean @default(true) @map("is_active")
  enablePdf        Boolean @default(false) @map("enable_pdf")
  allowEmployeePdf Boolean @default(false) @map("allow_employee_pdf")
  createdAt        DateTime @default(now()) @map("created_at")

  company       Company                    @relation(fields: [companyId], references: [id])
  fields        CustomRequestTypeField[]
  approvalRules ApprovalRule[]

  @@map("custom_request_types")
}

model CustomRequestTypeField {
  id           String  @id @default(uuid())
  customTypeId String  @map("custom_type_id")
  fieldName    String  @map("field_name") @db.VarChar(100)
  fieldType    String  @map("field_type") @db.VarChar(30)
  isRequired   Boolean @default(false) @map("is_required")
  options      Json?
  description  String? @db.Text
  imageUrl     String? @map("image_url") @db.Text
  sortOrder    Int     @map("sort_order")

  customType CustomRequestType @relation(fields: [customTypeId], references: [id], onDelete: Cascade)

  @@map("custom_request_type_fields")
}

model Request {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  requesterId String   @map("requester_id")
  type        String   @db.VarChar(30)
  payload     Json
  status      String   @default("PENDING") @db.VarChar(20)
  documentId  String?  @unique @map("document_id")
  // §6.6 #3 결재 규칙 스냅샷 — 요청 접수 시 적용된 규칙 id 기록(감사 추적, 규칙 변경 소급 방지)
  ruleId      String?  @map("rule_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  requester  Employee         @relation(fields: [requesterId], references: [id])
  document   Document?        @relation(fields: [documentId], references: [id])
  rule       ApprovalRule?    @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  approvals  RequestApproval[]

  @@index([requesterId, status])
  @@index([companyId, status])
  @@map("requests")
}

model ApprovalRule {
  id               String  @id @default(uuid())
  companyId        String  @map("company_id")
  name             String  @db.VarChar(100)
  requestType      String  @map("request_type") @db.VarChar(30)
  customTypeId     String? @map("custom_type_id")
  priority         Int     @default(0)
  scopeOrgIds      Json?   @map("scope_org_ids")
  scopePositionIds Json?   @map("scope_position_ids")
  maxApprovalRounds Int    @default(1) @map("max_approval_rounds")
  isAutoApprove    Boolean @default(false) @map("is_auto_approve")
  advancedSettings Json?   @map("advanced_settings")
  isActive         Boolean @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")

  company    Company             @relation(fields: [companyId], references: [id])
  customType CustomRequestType?  @relation(fields: [customTypeId], references: [id])
  details    ApprovalRuleDetail[]
  requests   Request[]

  @@map("approval_rules")
}

model ApprovalRuleDetail {
  id                String  @id @default(uuid())
  ruleId            String  @map("rule_id")
  tag               String? @db.VarChar(30)
  round             Int     @default(1)
  requiredCount     Int     @default(1) @map("required_count")
  approverPositionId String? @map("approver_position_id")
  isForbidden       Boolean @default(false) @map("is_forbidden")
  sortOrder         Int     @map("sort_order")

  rule             ApprovalRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  approverPosition Position?    @relation(fields: [approverPositionId], references: [id])

  @@map("approval_rule_details")
}

model RequestApproval {
  id         String    @id @default(uuid())
  requestId  String    @map("request_id")
  round      Int       @default(1)
  approverId String    @map("approver_id")
  status     String    @db.VarChar(20)
  comment    String?   @db.Text
  actedAt    DateTime? @map("acted_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  request Request @relation(fields: [requestId], references: [id])

  @@map("request_approvals")
}

// ════════════════════════════════════════════════
// 9. 전자결재
// ════════════════════════════════════════════════

// AP-01 양식함 — 기안양식 분류(카테고리)
model FormCategory {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  name      String   @db.VarChar(100)
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company        @relation(fields: [companyId], references: [id])
  forms   DocumentForm[]

  @@index([companyId, isActive])
  @@map("form_categories")
}

// AP — 문서성격(채번 대분류). 예: 사업관리/일반관리/인사관리/LABL CHINA.
// 양식함 분류(FormCategory)와 별개 축 — 기안 작성 시 선택하며 문서번호 {CATEGORY} 약어로 쓰인다.
model DocumentCategory {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  name         String   @db.VarChar(100)
  abbreviation String   @db.VarChar(20)
  sortOrder    Int      @default(0) @map("sort_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company   Company    @relation(fields: [companyId], references: [id])
  documents Document[]

  @@unique([companyId, name])
  @@unique([companyId, abbreviation])
  @@index([companyId, isActive])
  @@map("document_categories")
}

model DocumentForm {
  id              String  @id @default(uuid())
  companyId       String  @map("company_id")
  formOwnerId     String? @map("form_owner_id")
  // AP-01 양식함 분류 (FormCategory). 레거시 free-text는 category 컬럼 유지(점진 이관).
  categoryId      String? @map("category_id")
  name            String  @db.VarChar(200)
  category        String? @db.VarChar(100)
  fieldsSchema    Json    @map("fields_schema")
  // AP-01 양식 메타: 공개범위(PUBLIC/DEPARTMENT/PRIVATE)·보존연한·문서번호 약어·설명
  visibilityScope String  @default("PUBLIC") @map("visibility_scope") @db.VarChar(20)
  retentionYears  Int?    @map("retention_years")
  abbreviation    String? @db.VarChar(20)
  description     String? @db.Text
  // AP-01-03 양식별 기본 결재선 — 상신 시 결재선 미지정이면 이 공용 결재선을 기본 적용
  defaultLineId   String? @map("default_line_id")
  sortOrder       Int     @default(0) @map("sort_order")
  allowReDraft    Boolean @default(false) @map("allow_re_draft")
  allowPreApproval Boolean @default(false) @map("allow_pre_approval")
  allowZipUpload  Boolean @default(false) @map("allow_zip_upload")
  isActive        Boolean @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company         Company              @relation(fields: [companyId], references: [id])
  categoryRef     FormCategory?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  defaultLine     SharedApprovalLine?  @relation("FormDefaultLine", fields: [defaultLineId], references: [id], onDelete: SetNull)
  accessRules     FormAccessRule[]
  numberRules     DocumentNumberRule[]
  documents       Document[]

  @@index([companyId, isActive])
  @@map("document_forms")
}

model FormAccessRule {
  id        String @id @default(uuid())
  formId    String @map("form_id")
  scopeType String @map("scope_type") @db.VarChar(20)
  scopeId   String @map("scope_id")

  form DocumentForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@map("form_access_rules")
}

model DocumentNumberRule {
  id          String  @id @default(uuid())
  companyId   String  @map("company_id")
  formId      String  @map("form_id")
  pattern     String  @db.VarChar(200)
  currentSeq  Int     @default(0) @map("current_seq")
  resetYearly Boolean @default(true) @map("reset_yearly")

  company Company      @relation(fields: [companyId], references: [id])
  form    DocumentForm @relation(fields: [formId], references: [id])

  @@map("document_number_rules")
}

model Document {
  id              String    @id @default(uuid())
  companyId       String    @map("company_id")
  formId          String    @map("form_id")
  // AP 문서성격(채번 대분류) — 기안 시 선택. 양식함 분류와 별개.
  categoryId      String?   @map("category_id")
  requestId       String?   @unique @map("request_id")
  docNumber       String?   @unique @map("doc_number") @db.VarChar(100)
  title           String    @db.VarChar(200)
  content         Json
  drafterId       String    @map("drafter_id")
  status          String    @default("DRAFT") @db.VarChar(20)
  visibilityScope String    @default("PRIVATE") @map("visibility_scope") @db.VarChar(20)
  submittedAt     DateTime? @map("submitted_at")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  company       Company          @relation(fields: [companyId], references: [id])
  // 양식 삭제로 문서가 연쇄삭제되지 않도록 Restrict 명시(기존 DB 기본값과 동일 — 마이그레이션 무발생).
  // 운영상 양식은 soft-delete만 사용하고 FORM_IN_USE 가드로 사용 중 삭제를 차단한다.
  form          DocumentForm     @relation(fields: [formId], references: [id], onDelete: Restrict)
  category      DocumentCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  request       Request?
  drafter       Employee         @relation("DocumentDrafter", fields: [drafterId], references: [id])
  approvalLines ApprovalLine[]
  history       ApprovalHistory[]
  attachments   DocumentAttachment[]

  @@index([companyId, status])
  @@index([drafterId, status])
  @@map("documents")
}

// AP-02-01 기안 첨부파일 (MinIO 오브젝트 스토리지) — 문서 삭제 시 Cascade
model DocumentAttachment {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  documentId  String   @map("document_id")
  uploaderId  String   @map("uploader_id")
  fileName    String   @map("file_name") @db.VarChar(255)
  storageKey  String   @unique @map("storage_key") @db.VarChar(500)
  contentType String   @map("content_type") @db.VarChar(150)
  size        Int
  createdAt   DateTime @default(now()) @map("created_at")

  company   Company  @relation(fields: [companyId], references: [id])
  document  Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  uploader  Employee @relation("AttachmentUploader", fields: [uploaderId], references: [id])

  @@index([documentId])
  @@map("document_attachments")
}

model ApprovalLine {
  id              String  @id @default(uuid())
  documentId      String  @map("document_id")
  name            String? @db.VarChar(100)
  isShared        Boolean @default(false) @map("is_shared")
  sharedLineRefId String? @map("shared_line_ref_id")

  document        Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  // 공용 결재선 원본 삭제 시 참조만 끊고(결재선 단계는 상신 시 복사되어 독립) SetNull 명시(기존 DB 기본값과 동일).
  sharedLineRef   SharedApprovalLine? @relation(fields: [sharedLineRefId], references: [id], onDelete: SetNull)
  steps           ApprovalStep[]

  @@map("approval_lines")
}

model ApprovalStep {
  id          String    @id @default(uuid())
  lineId      String    @map("line_id")
  role        String    @db.VarChar(30)
  assigneeId  String    @map("assignee_id")
  // AP-04-02/06 부서협조·부서수신 대상 부서 (DEPT_* role에서만 설정; assignee는 해당 부서 문서담당자)
  organizationId String? @map("organization_id")
  stepOrder   Int       @map("step_order")
  isParallel  Boolean   @default(false) @map("is_parallel")
  status      String    @default("PENDING") @db.VarChar(20)
  comment     String?   @db.Text
  isProxy     Boolean   @default(false) @map("is_proxy")
  proxyId     String?   @map("proxy_id")
  proxyReason String?   @map("proxy_reason") @db.Text
  actedAt     DateTime? @map("acted_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  line     ApprovalLine @relation(fields: [lineId], references: [id], onDelete: Cascade)
  assignee Employee     @relation("StepAssignee", fields: [assigneeId], references: [id])
  organization Organization? @relation("StepDept", fields: [organizationId], references: [id], onDelete: SetNull)
  proxy    Employee?    @relation("StepProxy", fields: [proxyId], references: [id])

  @@index([assigneeId, status])
  @@map("approval_steps")
}

model ApprovalHistory {
  id         String   @id @default(uuid())
  documentId String   @map("document_id")
  stepId     String?  @map("step_id")
  actorId    String   @map("actor_id")
  action     String   @db.VarChar(50)
  comment    String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id])
  actor    Employee @relation(fields: [actorId], references: [id])

  @@index([documentId, createdAt(sort: Desc)])
  @@map("approval_history")
}

model ProxySettings {
  id          String   @id @default(uuid())
  principalId String   @map("principal_id")
  proxyId     String   @map("proxy_id")
  startDate   DateTime @db.Date @map("start_date")
  endDate     DateTime @db.Date @map("end_date")
  reason      String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  principal Employee @relation("ProxPrincipal", fields: [principalId], references: [id])
  proxy     Employee @relation("ProxyAgent", fields: [proxyId], references: [id])

  @@map("proxy_settings")
}

model SharedApprovalLine {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  name        String   @db.VarChar(100)
  steps       Json
  version     Int      @default(1)
  // 결재선 범위 — COMPANY(공용, 관리자 관리·전 직원 사용) | PERSONAL(개인, 작성자 본인만 관리·사용)
  scope       String   @default("COMPANY") @db.VarChar(20)
  // 작성자 (공용: 감사/표시용 · 개인: 소유자) — 직원 삭제 시 SetNull
  createdById String?  @map("created_by_id")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdAt   DateTime @default(now()) @map("created_at")

  company       Company        @relation(fields: [companyId], references: [id])
  createdBy     Employee?      @relation("SharedLineCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  approvalLines ApprovalLine[]
  defaultForForms DocumentForm[] @relation("FormDefaultLine")

  @@index([companyId, scope, createdById])
  @@map("shared_approval_lines")
}

