model MessageTemplate {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  name         String   @db.VarChar(100)
  content      String   @db.Text
  hasVariables Boolean  @default(false) @map("has_variables")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company    Company             @relation(fields: [companyId], references: [id])
  automations MessageAutomation[]
  notificationRules NotificationRule[]
  messages   Message[]

  @@map("message_templates")
}

model MessageAutomation {
  id            String   @id @default(uuid())
  companyId     String   @map("company_id")
  name          String   @db.VarChar(100)
  automationType String  @map("automation_type") @db.VarChar(30)
  leaveTypeId   String?  @map("leave_type_id")
  triggerBasis  String   @map("trigger_basis") @db.VarChar(20)
  offsetDays    Int      @map("offset_days")
  sendTime      DateTime @map("send_time") @db.Time
  timezone      String   @default("Asia/Seoul")
  templateId    String   @map("template_id")
  sendEmail     Boolean  @default(false) @map("send_email")
  isActive      Boolean  @default(true) @map("is_active")
  startsAt      DateTime @db.Date @map("starts_at")
  createdAt     DateTime @default(now()) @map("created_at")

  company   Company         @relation(fields: [companyId], references: [id])
  leaveType LeaveType?      @relation(fields: [leaveTypeId], references: [id])
  template  MessageTemplate @relation(fields: [templateId], references: [id])

  @@map("message_automations")
}

model Message {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  senderId     String?  @map("sender_id")
  automationId String?  @map("automation_id")
  templateId   String?  @map("template_id")
  type         String   @db.VarChar(20)
  title        String?  @db.VarChar(200)
  content      String   @db.Text
  sendEmail    Boolean  @default(false) @map("send_email")
  sentAt       DateTime @default(now()) @map("sent_at")

  company    Company            @relation(fields: [companyId], references: [id])
  sender     Employee?          @relation(fields: [senderId], references: [id])
  template   MessageTemplate?   @relation(fields: [templateId], references: [id])
  recipients MessageRecipient[]

  @@index([companyId, sentAt(sort: Desc)])
  @@map("messages")
}

model MessageRecipient {
  id          String    @id @default(uuid())
  messageId   String    @map("message_id")
  recipientId String    @map("recipient_id")
  readAt      DateTime? @map("read_at")
  note        String?   @db.Text

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([recipientId, readAt])
  @@map("message_recipients")
}

// ════════════════════════════════════════════════
// 12. 알림
// ════════════════════════════════════════════════

model NotificationRule {
  id                String  @id @default(uuid())
  companyId         String  @map("company_id")
  eventType         String  @map("event_type") @db.VarChar(50)
  channelType       String  @map("channel_type") @db.VarChar(20)
  webhookUrl        String? @map("webhook_url") @db.Text
  triggerCondition  Json?   @map("trigger_condition")
  embedTemplate     Json?   @map("embed_template")
  messageTemplateId String? @map("message_template_id")
  isActive          Boolean @default(true) @map("is_active")
  cronExpression    String? @map("cron_expression") @db.VarChar(100)
  createdAt         DateTime @default(now()) @map("created_at")

  company         Company          @relation(fields: [companyId], references: [id])
  messageTemplate MessageTemplate? @relation(fields: [messageTemplateId], references: [id])
  logs            NotificationLog[]

  @@index([companyId, eventType, isActive])
  @@map("notification_rules")
}

model NotificationLog {
  id           String    @id @default(uuid())
  ruleId       String?   @map("rule_id")
  eventType    String    @map("event_type") @db.VarChar(50)
  payload      Json?
  status       String    @db.VarChar(20)
  retryCount   Int       @default(0) @map("retry_count")
  errorMessage String?   @map("error_message") @db.Text
  sentAt       DateTime  @default(now()) @map("sent_at")

  rule NotificationRule? @relation(fields: [ruleId], references: [id])

  @@index([ruleId, sentAt(sort: Desc)])
  @@map("notification_logs")
}

// 감사 로그 — 관리자 행위 추적 (출퇴근 수정·휴가 부여·설정 변경 등).
// 다른 도메인 참조는 느슨하게 문자열 id로만 보관(삭제 가드 회피).
model AuditLog {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  actorId     String?  @map("actor_id")
  actorName   String   @map("actor_name") @db.VarChar(100)
  action      String   @db.VarChar(50)
  targetType  String   @map("target_type") @db.VarChar(50)
  targetId    String?  @map("target_id")
  targetLabel String?  @map("target_label") @db.VarChar(200)
  result      String   @default("SUCCESS") @db.VarChar(20)
  detail      Json?
  createdAt   DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, createdAt(sort: Desc)])
  @@map("audit_logs")
}

/// API 에러 분석 로그 — GlobalExceptionFilter가 잡은 에러를 회사 AI로 분석한 결과를 보관.
/// 이메일/Discord 발송과 별개로 영속화하여 관리자 화면(부가기능 > AI 에러 분석)에서 조회한다.
model ErrorAnalysisLog {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  /// HTTP 상태 코드 (400·500 등)
  status          Int
  /// 에러 코드 (VALIDATION_ERROR·INTERNAL_SERVER_ERROR 등)
  code            String   @db.VarChar(80)
  /// 사용자 표시 메시지
  message         String   @db.Text
  /// 요청 메서드 (GET·POST 등)
  method          String   @db.VarChar(10)
  /// 요청 경로
  path            String   @db.VarChar(500)
  /// 인증된 요청이면 사용자 ID(JWT sub)
  userId          String?  @map("user_id")
  /// 검증 실패 등 상세(4xx)
  detail          Json?
  /// 서버 오류 스택(5xx)
  stack           String?  @db.Text
  /// 회사 AI가 생성한 원인/조치 분석 (미설정/실패 시 null)
  aiAnalysis      String?  @map("ai_analysis") @db.Text
  /// 분석 시점 회사 AI 활성 여부
  aiEnabled       Boolean  @default(false) @map("ai_enabled")
  /// 이메일 발송 성공 여부
  notifiedEmail   Boolean  @default(false) @map("notified_email")
  /// Discord 경고 발송 성공 여부
  notifiedDiscord Boolean  @default(false) @map("notified_discord")
  /// 처리 상태 — OPEN(미해결) | RESOLVED(완료). 관리자가 일괄 완료 처리.
  resolutionStatus String  @default("OPEN") @map("resolution_status") @db.VarChar(20)
  /// 완료 처리 시각(미해결이면 null)
  resolvedAt      DateTime? @map("resolved_at")
  /// 완료 처리한 관리자(직원). 직원 삭제 시 NULL로 보존
  resolvedById    String?  @map("resolved_by_id")
  createdAt       DateTime @default(now()) @map("created_at")

  company    Company   @relation(fields: [companyId], references: [id])
  resolvedBy Employee? @relation("ErrorResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt(sort: Desc)])
  @@index([companyId, status])
  @@index([companyId, resolutionStatus])
  @@map("error_analysis_logs")
}

/// 메신저 계정 연동 — 직원 ↔ 메신저(Discord 등) 사용자 매핑 (메신저 양방향 결재 PoC).
/// 버튼 클릭자(externalUserId) → employee/company 역해석으로 결재 본인 검증에 사용.
model MessengerAccount {
  id             String   @id @default(uuid())
  companyId      String   @map("company_id")
  employeeId     String   @map("employee_id")
  platform       String   @db.VarChar(20) // 'discord' | 'kakaowork' | 'naverworks'
  externalUserId String   @map("external_user_id") @db.VarChar(100)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([platform, externalUserId])
  @@unique([companyId, employeeId, platform])
  @@index([companyId])
  @@map("messenger_accounts")
}
